<resources>
    <style name="KeyButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">14sp</item>
        <item name="backgroundTint">@color/tyrion_key_bg</item>
        <item name="android:textColor">@color/tyrion_dark_text</item>
        <item name="cornerRadius">10dp</item>
    </style>

    <style name="KeyButtonAccent" parent="KeyButton">
        <item name="backgroundTint">@color/tyrion_plum</item>
        <item name="android:textColor">@color/tyrion_white</item>
    </style>
</resources>
