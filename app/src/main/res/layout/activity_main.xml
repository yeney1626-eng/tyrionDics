<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tyrion_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@mipmap/ic_launcher"
                android:layout_marginEnd="10dp"
                android:contentDescription="@string/app_name" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/tyrion_dark_text"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_intro"
            android:textColor="@color/tyrion_dark_text"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnOpenSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_open_settings"
            android:backgroundTint="@color/tyrion_rust"
            android:textColor="@color/tyrion_white"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnPickKeyboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_pick_keyboard"
            android:backgroundTint="@color/tyrion_plum"
            android:textColor="@color/tyrion_white"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnGrantOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_grant_overlay"
            android:backgroundTint="@color/tyrion_rust"
            android:textColor="@color/tyrion_white"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvOverlayStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/tyrion_dark_text"
            android:textSize="12sp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_keys_help"
            android:textColor="@color/tyrion_dark_text"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/test_field_label"
            android:textColor="@color/tyrion_plum"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/testField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="3"
            android:gravity="top|start"
            android:background="@color/tyrion_white"
            android:padding="12dp"
            android:textColor="@color/tyrion_dark_text"
            android:inputType="textMultiLine" />

    </LinearLayout>
</ScrollView>
